  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolt-mcb/pi-goal.git"
  },
  "bugs": {
    "url": "https://github.com/kolt-mcb/pi-goal/issues"
  },
  "homepage": "https://github.com/kolt-mcb/pi-goal#readme",
